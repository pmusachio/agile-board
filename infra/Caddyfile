{$DOMAIN} {
	# Gitea UI, git-over-HTTP(S), and API, reverse-proxied under /git/.
	handle_path /git/* {
		reverse_proxy gitea:3000
	}

	# MVP2 assistant backend — /api/ask, /api/propose.
	# Unlike /git/* above, this uses `handle` (not `handle_path`): the
	# assistant's own routes are literally /api/ask etc (assistant/server.mjs),
	# so the /api prefix must reach it unstripped. Not reachable any other
	# way: no host port mapping on assistant-api.
	handle /api/* {
		reverse_proxy assistant-api:3100
	}

	# EPIC-013: the wiki (Quartz static build, rebuilt by the post-receive
	# hook alongside stories/index.json). Quartz emits clean URLs (no .html
	# extension) -- try_files resolves them against the files actually on
	# disk, same recipe Caddy's own docs give for any static site like this.
	handle_path /wiki/* {
		root * /srv/wiki
		try_files {path} {path}.html {path}/index.html /404.html
		file_server
	}

	# The published board (and repo files in general) — static, read-only.
	# Public board link: https://{$DOMAIN}/board/
	handle {
		root * /srv/board
		file_server
	}
}
