# Copy to .env (gitignored) and fill in before `docker compose up -d`.
# DOMAIN must already resolve to this VM's public IP.
DOMAIN=board.example.duckdns.org

# MVP2 assistant backend. Get a key at https://ai.google.dev. GEMINI_MODEL is
# optional — leave it unset to use the client's built-in default.
GEMINI_API_KEY=
GEMINI_MODEL=
