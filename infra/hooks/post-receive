#!/bin/sh
# Publish hook: on every push to main, checks the new tree out directly into
# /srv/board (the directory Caddy serves as static files) and rebuilds
# stories/index.json + stories/graph.json. Runs inside the gitea container
# (needs `node` on PATH — see gitea.Dockerfile).
#
# Install by copying this file to the bare repo's own hooks/post-receive,
# e.g. /data/git/repositories/<owner>/<repo>.git/hooks/post-receive inside the
# gitea container, and `chmod +x` it.
set -eu

TARGET_DIR=/srv/board
BRANCH=main
REPO_DIR=$(pwd) # git invokes hooks with cwd = the bare repo (<repo>.git)

while read -r old_sha new_sha ref_name; do
  [ "$ref_name" = "refs/heads/$BRANCH" ] || continue
  git --git-dir="$REPO_DIR" --work-tree="$TARGET_DIR" checkout -f "$BRANCH"
  ( cd "$TARGET_DIR" && node scripts/build-manifest.mjs && node scripts/build-graph.mjs )
  echo "agile-board: published $new_sha to $TARGET_DIR"

  # EPIC-013: rebuild the wiki (Quartz, static output to /srv/wiki). npm ci
  # only on the very first run after a deploy -- node_modules survives
  # `checkout -f` (gitignored, so git never touches it), and re-running a
  # full clean install on every single push would make ordinary pushes
  # noticeably slower for no reason once wiki/package-lock.json is settled.
  if [ ! -d "$TARGET_DIR/wiki/node_modules" ]; then
    ( cd "$TARGET_DIR/wiki" && npm ci --omit=dev )
  fi
  export WIKI_CONTENT_DIR=/tmp/agile-board-wiki-content
  node "$TARGET_DIR/scripts/build-wiki-content.mjs"
  ( cd "$TARGET_DIR/wiki" && npx quartz build -d "$WIKI_CONTENT_DIR" -o /srv/wiki )
  echo "agile-board: published wiki for $new_sha to /srv/wiki"
done
